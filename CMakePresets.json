    },
    {
      "name": "homebrew-clang-debug",
      "displayName": "Homebrew Clang Debug",
      "configurePreset": "homebrew-clang-debug"
    },
    {
      "name": "homebrew-clang-release",
      "displayName": "Homebrew Clang Release",
      "configurePreset": "homebrew-clang-release"
    },
    {
      "name": "homebrew-clang-vcpkg-debug",
      "displayName": "Homebrew Clang Debug (vcpkg)",
      "configurePreset": "homebrew-clang-vcpkg-debug"
    },
    {
      "name": "homebrew-clang-vcpkg-release",
      "displayName": "Homebrew Clang Release (vcpkg)",
      "configurePreset": "homebrew-clang-vcpkg-release"
    },
    {
      "name": "msvc-debug",
      "displayName": "MSVC Debug",
      "configurePreset": "msvc-debug"
    },
    {
      "name": "msvc-release",
      "displayName": "MSVC Release",
      "configurePreset": "msvc-release"
    },
    {
      "name": "msvc-vcpkg-debug",
      "displayName": "MSVC Debug (vcpkg)",
      "configurePreset": "msvc-vcpkg-debug"
    },
    {
      "name": "msvc-vcpkg-release",
      "displayName": "MSVC Release (vcpkg)",
      "configurePreset": "msvc-vcpkg-release"
    }
  ]
}