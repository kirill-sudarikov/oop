{
  "version": 9,
  "configurePresets": [
    {
      "name": "ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "generator": "Ninja",
      "hidden": true
    },
    {
      "name": "vcpkg",
      "hidden": true,
      "toolchainFile": "/home/kirill/vcpkg/scripts/buildsystems/vcpkg.cmake"
    },
    {
      "name": "debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      },
      "hidden": true
    },
    {
      "name": "release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      },
      "hidden": true
    },
    {
      "name": "gcc",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++"
      },
      "hidden": true
    },
    {
      "name": "gcc-debug",
      "inherits": [
        "ninja",
        "gcc",
        "debug"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "gcc-release",
      "inherits": [
        "ninja",
        "gcc",
        "release"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "gcc-vcpkg-debug",
      "inherits": [
        "ninja",
        "gcc",
        "vcpkg",
        "debug"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "gcc-vcpkg-release",
      "inherits": [
        "ninja",
        "gcc",
        "vcpkg",
        "release"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "homebrew-clang",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_CXX_STDLIB_MODULES_JSON": "/opt/homebrew/opt/llvm/lib/c++/libc++.modules.json",
        "CMAKE_OSX_SYSROOT": "macosx"
      },
      "hidden": true
    },
    {
      "name": "homebrew-clang-debug",
      "inherits": [
        "ninja",
        "homebrew-clang",
        "debug"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "homebrew-clang-release",
      "inherits": [
        "ninja",
        "homebrew-clang",
        "release"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "homebrew-clang-vcpkg-debug",
      "inherits": [
        "ninja",
        "homebrew-clang",
        "vcpkg",
        "debug"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "homebrew-clang-vcpkg-release",
      "inherits": [
        "ninja",
        "homebrew-clang",
        "vcpkg",
        "release"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "msvc",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "cl.exe"
      },
      "hidden": true
    },
    {
      "name": "msvc-debug",
      "inherits": [
        "ninja",
        "msvc",
        "debug"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "msvc-release",
      "inherits": [
        "ninja",
        "msvc",
        "release"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "msvc-vcpkg-debug",
      "inherits": [
        "ninja",
        "msvc",
        "vcpkg",
        "debug"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "msvc-vcpkg-release",
      "inherits": [
        "ninja",
        "msvc",
        "vcpkg",
        "release"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "gcc-debug",
      "displayName": "GCC Debug",
      "configurePreset": "gcc-debug"
    },
    {
      "name": "gcc-release",
      "displayName": "GCC Release",
      "configurePreset": "gcc-release"
    },
    {
      "name": "gcc-vcpkg-debug",
      "displayName": "GCC Debug (vcpkg)",
      "configurePreset": "gcc-vcpkg-debug"
    },
    {
      "name": "gcc-vcpkg-release",
      "displayName": "GCC Release (vcpkg)",
